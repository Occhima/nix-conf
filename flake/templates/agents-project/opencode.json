{
  "$schema": "https://opencode.ai/config.json",
  "mcp": {
    "codegraph": {
      "command": ["codegraph", "serve", "--mcp"],
      "enabled": true,
      "type": "local"
    },
    "agentmemory": {
      "command": ["agentmemory", "mcp"],
      "enabled": true,
      "environment": {
        "AGENTMEMORY_URL": "http://localhost:3111",
        "AGENTMEMORY_SECRET": "{env:AGENTMEMORY_SECRET}"
      },
      "type": "local"
    }
  },
  "permission": {
    "read": {
      "*": "allow",
      "./.env": "deny",
      "./.env.*": "deny",
      "./secrets/**": "deny",
      "./venv/**": "deny",
      "./config/credentials.json": "deny"
    }
  }
}
